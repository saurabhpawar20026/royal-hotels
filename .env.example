# Copy this file to ".env" and fill in your values (".env" is git-ignored).

# Your UPI ID (VPA) for the "Scan & Pay" QR tab, e.g. name@bank
VITE_PAYEE_VPA=your-upi-id@bank
VITE_PAYEE_NAME=Royal Hotels

# Payment backend base URL (optional; defaults to http://localhost:5000)
# VITE_API_BASE=http://localhost:5000
